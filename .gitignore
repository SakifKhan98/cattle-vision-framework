# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Large data (download separately — see docs/datasets.md)
data/raw/
data/processed/
data/rfdetr_seg/
data/rfdetr_seg_eval/

# Model weights and checkpoints (download from HuggingFace — see docs/setup.md)
weights/
runs/
models/
*.pth
*.pt
*.tar.gz
*.ckpt

# Archive — safe to delete after verifying pipeline
_archive/

# Third-party source repos (populated by setup steps — see docs/setup.md)
third_party/

# Large result artifacts (keep summaries, not raw outputs)
# NOTE: results/behavior/predictions/ is COMMITTED (17 MB, needed for analytics)
results/analytics/timelines/
results/tracking/videos/
results/tracking/visualizations/
results/segmentation/viz/

# Inference pipeline outputs (per-job directories with large intermediates + MP4s)
results/inference/
# Allow committed analytics CSVs from the inference pipeline
!results/inference/
!results/inference/freeman/
!results/inference/freeman/timing.csv
!results/inference/freeman/*/
!results/inference/freeman/*/activity_budget.csv
!results/inference/freeman/*/behavior_deviation.csv
!results/inference/freeman/*/transition_matrix.csv
!results/inference/freeman/*/timing.csv
!results/inference/freeman/*/timelines/
!results/inference/freeman/*/timelines/*.csv

# Video files (too large for git)
*.mp4
*.avi
*.mov

# Binary document originals (converted to .md in docs/design/reports/)
*.docx
docs/**/*.pdf

# Dataset paper markdown conversions (local reference only, not committed)
docs/dataset-papers/*.md

# Notebook outputs
notebooks/.ipynb_checkpoints/

# Frontend build artifacts
ui/dist/
ui/node_modules/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
